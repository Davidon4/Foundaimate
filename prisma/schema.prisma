generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
  relationMode = "prisma"
}

model Ownership {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String
}

model Experience {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String
}

model Expertise {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String
}

model Stage {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String       
}

model Revenue {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String 
}

model Network {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String 
}

model Industry {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String 
}

model Size {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String 
}

model Product {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String 
}
