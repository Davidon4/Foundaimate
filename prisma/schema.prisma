// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
  relationMode = "prisma"
}

model Ownership {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  profiles    Profile[]    
}

model Experience {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  profiles    Profile[] 
}

model Expertise {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  profiles    Profile[] 
}

model Stage {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String  
  profiles    Profile[]      
}

model Revenue {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String 
  profiles    Profile[] 
}

model Network {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  profiles    Profile[]  
}

model Industry {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  profiles    Profile[]  
}

model Size {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String 
  profiles    Profile[] 
}

model Product {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String 
  profiles    Profile[] 
}

model Decision {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  profiles    Profile[]  
}

model Target {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String 
  profiles    Profile[] 
}

model Member {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String 
  members    Profile[] 
}

model SChallenge {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String 
  members    Profile[] 
}

model SStrategy {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String 
  members    Profile[] 
}

model Lead {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String 
  members    Profile[] 
}

model MChannel {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String 
  members    Profile[] 
}

model MChallenge {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String 
  members    Profile[] 
}

model Usp {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String 
  members    Profile[] 
}

model MGoal {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String 
  members    Profile[] 
}

model SGoal {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String 
  members    Profile[] 
}

model DChallenge {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String 
  members    Profile[] 
}

model Feature {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String 
  members    Profile[] 
}

model Update {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String 
  members    Profile[] 
}

model Innovation {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String 
  members    Profile[] 
}

model DRisk {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String 
  members    Profile[] 
}

model MRisk {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String 
  members    Profile[] 
}

model SRisk {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String 
  members    Profile[] 
}

model DGoal {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String 
  members    Profile[] 
}

model Personality {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  role          String
  motto         String
  coreTraits    Json
  toneExamples  Json
  sampleInteraction Json
  summary       String
  imageUrl      String?   // Optional field for the image URL
  members       Profile[]
}


model Profile {
  id            String @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  description   String
  userId        String

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  experience    Experience  @relation(fields: [experienceId], references: [id])
  experienceId  String  @db.ObjectId

  ownership     Ownership  @relation(fields: [ownershipId], references: [id])
  ownershipId   String  @db.ObjectId

  expertise     Expertise  @relation(fields: [expertiseId], references: [id])
  expertiseId   String  @db.ObjectId

  stage         Stage  @relation(fields: [stageId], references: [id])
  stageId       String  @db.ObjectId

  revenue       Revenue  @relation(fields: [revenueId], references: [id])
  revenueId     String  @db.ObjectId

  network       Network  @relation(fields: [networkId], references: [id])
  networkId     String  @db.ObjectId

  industry      Industry  @relation(fields: [industryId], references: [id])
  industryId    String  @db.ObjectId

  size          Size  @relation(fields: [sizeId], references: [id])
  sizeId        String  @db.ObjectId

  product       Product  @relation(fields: [productId], references: [id])
  productId     String  @db.ObjectId

  decision      Decision  @relation(fields: [decisionId], references: [id])
  decisionId    String  @db.ObjectId

  target        Target  @relation(fields: [targetId], references: [id])
  targetId      String  @db.ObjectId

  member        Member  @relation(fields: [memberId], references: [id])
  memberId      String  @db.ObjectId

  schallenge    SChallenge  @relation(fields: [schallengeId], references: [id])
  schallengeId  String  @db.ObjectId

  sstrategy     SStrategy  @relation(fields: [sstrategyId], references: [id])
  sstrategyId   String  @db.ObjectId

  lead          Lead  @relation(fields: [leadId], references: [id])
  leadId        String  @db.ObjectId

  mchannel      MChannel  @relation(fields: [mchannelId], references: [id])
  mchannelId    String  @db.ObjectId

  usp           Usp  @relation(fields: [uspId], references: [id])
  uspId         String  @db.ObjectId

  mchallenge    MChallenge  @relation(fields: [mchallengeId], references: [id])
  mchallengeId  String  @db.ObjectId

  mgoal         MGoal  @relation(fields: [mgoalId], references: [id])
  mgoalId       String  @db.ObjectId

  sgoal         SGoal  @relation(fields: [sgoalId], references: [id])
  sgoalId       String  @db.ObjectId

  dchallenge    DChallenge  @relation(fields: [dchallengeId], references: [id])
  dchallengeId  String  @db.ObjectId

  feature       Feature  @relation(fields: [featureId], references: [id])
  featureId     String  @db.ObjectId

  update       Update  @relation(fields: [updateId], references: [id])
  updateId     String  @db.ObjectId

  innovation    Innovation  @relation(fields: [innovationId], references: [id])
  innovationId  String  @db.ObjectId

  drisk         DRisk  @relation(fields: [driskId], references: [id])
  driskId       String  @db.ObjectId
  
  mrisk         MRisk  @relation(fields: [mriskId], references: [id])
  mriskId       String  @db.ObjectId

  srisk         SRisk  @relation(fields: [sriskId], references: [id])
  sriskId       String  @db.ObjectId
  
  dgoal         DGoal  @relation(fields: [dgoalId], references: [id])
  dgoalId       String  @db.ObjectId

  personality         Personality  @relation(fields: [personalityId], references: [id])
  personalityId       String  @db.ObjectId

  @@index([experienceId])
  @@index([ownershipId])
  @@index([expertiseId])
  @@index([stageId])
  @@index([revenueId])
  @@index([networkId])
  @@index([industryId])
  @@index([sizeId])
  @@index([productId])
  @@index([decisionId])
  @@index([targetId])
  @@index([memberId])
  @@index([schallengeId])
  @@index([sstrategyId])
  @@index([leadId])
  @@index([mchannelId])
  @@index([mchallengeId])
  @@index([uspId])
  @@index([sgoalId])
  @@index([mgoalId])
  @@index([dchallengeId])
  @@index([featureId])
  @@index([updateId])
  @@index([innovationId])
  @@index([driskId])
  @@index([sriskId])
  @@index([mriskId])
  @@index([dgoalId])
  @@index([personalityId])
  @@index([name], name: "name_text_idx") // Text index for full-text search
}